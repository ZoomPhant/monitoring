---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  sidebar?: { title: string; href: string; children?: { title: string; href: string }[] }[];
  currentPath?: string;
}

const { title, description, sidebar = [], currentPath = '' } = Astro.props;
---

<BaseLayout title={`${title} — ZoomPhant Docs`} description={description}>
  <Header currentPath={currentPath} />
  <div class="mx-auto flex min-h-[calc(100vh-4rem)] max-w-7xl px-6">
    <!-- Sidebar -->
    <aside class="hidden w-56 flex-shrink-0 lg:block">
      <nav class="sticky top-16 -ml-2 overflow-y-auto py-8 pr-4" style="max-height: calc(100vh - 4rem)">
        <div class="mb-6 px-2">
          <h3 class="text-xs font-semibold uppercase tracking-wider text-gray-400">Documentation</h3>
        </div>
        <ul class="space-y-1">
          {
            sidebar.map((section) => (
              <li>
                <a
                  href={section.href}
                  class:list={[
                    'block rounded-lg px-3 py-2 text-sm font-medium transition-colors',
                    currentPath === section.href
                      ? 'bg-brand-100 text-brand-700'
                      : 'text-gray-600 hover:bg-gray-100 hover:text-gray-900'
                  ]}
                >
                  {section.title}
                </a>
                {section.children && section.children.length > 0 && (
                  <ul class="ml-3 mt-1 space-y-1 border-l border-gray-200 pl-3">
                    {
                      section.children.map((child) => (
                        <li>
                          <a
                            href={child.href}
                            class:list={[
                              'block rounded-lg px-3 py-1.5 text-sm transition-colors',
                              currentPath === child.href
                                ? 'bg-brand-50 text-brand-600 font-medium'
                                : 'text-gray-500 hover:text-gray-900'
                            ]}
                          >
                            {child.title}
                          </a>
                        </li>
                      ))
                    }
                  </ul>
                )}
              </li>
            ))
          }
        </ul>
      </nav>
    </aside>

    <!-- Main content -->
    <main class="min-w-0 flex-1 border-l border-gray-100">
      <div class="mx-auto max-w-3xl px-6 py-12 sm:px-10 lg:px-12">
        <article class="doc-content">
          <h1 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">{title}</h1>
          <div class="mt-8">
            <slot />
          </div>
        </article>
        <footer class="mt-16 border-t border-gray-100 pt-8">
          <div class="flex items-center gap-2 text-sm text-gray-500">
            <span>Found an issue?</span>
            <a href="https://github.com/ZoomPhant/monitoring/issues/new" class="font-medium text-brand-600 hover:text-brand-700">Report on GitHub</a>
          </div>
        </footer>
      </div>
    </main>
  </div>
  <Footer />
</BaseLayout>
